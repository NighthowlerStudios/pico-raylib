[submodule "pico-sdk"]
	path = pico-sdk
	url = https://github.com/RaspberryPi/pico-sdk
[submodule "raylib"]
	path = raylib
	url = https://github.com/NighthowlerStudios/raylib
[submodule "sparkfun-pico"]
	path = sparkfun-pico
	url = https://github.com/NighthowlerStudios/sparkfun-pico
[submodule "pico-extras"]
	path = pico-extras
	url = https://github.com/RaspberryPi/pico-extras
[submodule "pico-vfs"]
	path = pico-vfs
	url = https://github.com/oyama/pico-vfs
